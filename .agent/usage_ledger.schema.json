{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Usage Ledger Event Schema",
  "type": "object",
  "required": [
    "timestamp_utc",
    "session_id",
    "release_id",
    "phase",
    "event_type",
    "actor",
    "paid_api_used",
    "external_sdk_used",
    "goal_mode_used",
    "estimated_cost_brl"
  ],
  "properties": {
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "session_id": { "type": "string" },
    "release_id": { "type": "string" },
    "phase": { "type": "string" },
    "event_type": {
      "type": "string",
      "enum": [
        "session_started",
        "phase_started",
        "command_executed",
        "validation_run",
        "validation_failed",
        "validation_passed",
        "retry_used",
        "ci_watch_started",
        "ci_watch_finished",
        "files_changed_reported",
        "artifacts_generated",
        "budget_checked",
        "human_approval_required",
        "human_approval_granted",
        "human_approval_denied",
        "session_finished"
      ]
    },
    "actor": { "type": "string" },
    "tool": { "type": "string" },
    "command_category": { "type": "string" },
    "estimated_cost_brl": { "type": "number", "minimum": 0 },
    "paid_api_used": { "type": "boolean" },
    "external_sdk_used": { "type": "boolean" },
    "goal_mode_used": { "type": "boolean" },
    "retry_count": { "type": "integer", "minimum": 0 },
    "ci_watch_minutes": { "type": "integer", "minimum": 0 },
    "files_changed_count": { "type": "integer", "minimum": 0 },
    "diff_lines_estimate": { "type": "integer" },
    "artifacts_generated_count": { "type": "integer", "minimum": 0 },
    "notes": { "type": "string" }
  }
}
